{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-Pipe-XXX"
		},
		"LinkedService_AzureDataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LinkedService_AzureDataLakeStorage'"
		},
		"Linked_Service_AzureSqlDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Linked_Service_AzureSqlDatabase'"
		},
		"ls_onprim_filesystem_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_onprim_filesystem'"
		},
		"LinkedService_AzureDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgen2xxx.dfs.core.windows.net/"
		},
		"Linked_Service_AzureSqlDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "test-sqlserver-xxx.database.windows.net"
		},
		"Linked_Service_AzureSqlDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "TestDB"
		},
		"Linked_Service_AzureSqlDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "mahmoud-eltabakh"
		},
		"ls_onprim_filesystem_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "C:\\"
		},
		"ls_onprim_filesystem_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "mahmoud-eltabak\\mahmoud eltabakh"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-Pipe-XXX_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LinkedService_AzureDataLakeStorage_accountKey": {
						"value": "[parameters('LinkedService_AzureDataLakeStorage_accountKey')]"
					},
					"Linked_Service_AzureSqlDatabase_password": {
						"value": "[parameters('Linked_Service_AzureSqlDatabase_password')]"
					},
					"ls_onprim_filesystem_password": {
						"value": "[parameters('ls_onprim_filesystem_password')]"
					},
					"LinkedService_AzureDataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('LinkedService_AzureDataLakeStorage_properties_typeProperties_url')]"
					},
					"Linked_Service_AzureSqlDatabase_properties_typeProperties_server": {
						"value": "[parameters('Linked_Service_AzureSqlDatabase_properties_typeProperties_server')]"
					},
					"Linked_Service_AzureSqlDatabase_properties_typeProperties_database": {
						"value": "[parameters('Linked_Service_AzureSqlDatabase_properties_typeProperties_database')]"
					},
					"Linked_Service_AzureSqlDatabase_properties_typeProperties_userName": {
						"value": "[parameters('Linked_Service_AzureSqlDatabase_properties_typeProperties_userName')]"
					},
					"ls_onprim_filesystem_properties_typeProperties_host": {
						"value": "[parameters('ls_onprim_filesystem_properties_typeProperties_host')]"
					},
					"ls_onprim_filesystem_properties_typeProperties_userId": {
						"value": "[parameters('ls_onprim_filesystem_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}